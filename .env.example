# Firebase Admin SDK credentials (server-side).
# Get these from Firebase Console -> Project Settings -> Service accounts -> Generate new private key.
# Set them as Environment Variables in Vercel (Project -> Settings -> Environment Variables).

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Paste the full private key. Keep the literal \n escape sequences (or wrap the real
# newlines in double quotes). The app normalizes \n into real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Optional: the ID of a NON-default (named) Firestore database. Leave unset to
# use the "(default)" database. If you created a new database in the Firebase
# Console, put its database ID here (NOT the display name) so writes/reads land
# in it instead of "(default)".
# FIREBASE_DATABASE_ID=your-database-id
